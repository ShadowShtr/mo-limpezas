# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Credenciais provisorias (segredos) - nunca commitar
CREDENCIAIS_COLABORADORES.local.md
*.local.md
Credenciais_Colaboradores.pdf
*credenciais*.pdf
*.local.pdf

# Ficheiros de dados de import (dados pessoais) - nunca commitar
scripts/*.local.json
scripts/_*.json
scripts/_*.mjs
*_data*.json

# Supabase CLI — cache/estado local temporário (regenerado pelo CLI)
supabase/.temp/
