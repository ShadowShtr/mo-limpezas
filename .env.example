# Copia este ficheiro para .env.local e preenche os valores

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoixxxxxx

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron — segredo para autorizar chamadas ao /api/cron/generate-services
CRON_SECRET=gera-um-segredo-aleatorio-aqui

# Resend — emails transacionais (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Mó Limpezas <noreply@molimpezas.pt>

# Empresa (usado nos templates de email/SMS)
COMPANY_PHONE=925 780 509

# Upstash Redis — rate limiting distribuído (OBRIGATÓRIO em produção)
# Sem estas variáveis em produção o servidor não arranca (fallback in-memory
# não é fiável em Vercel serverless com múltiplas instâncias).
# Cria um database gratuito em https://upstash.com → Redis → Create Database
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=
